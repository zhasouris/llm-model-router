# ---------------------------------------------------------------------------
# corgi-ai-gateway — environment template
#
# Copy this file to `.env` and fill in real values. The real `.env` is
# gitignored and must never be committed. Only secrets belong here; non-secret
# configuration (model catalog, strategies, classifier, OTel) lives in
# config/*.yaml. See docs/decisions/0004-stack-and-project-layout.md.
# ---------------------------------------------------------------------------

# --- Provider credentials (held centrally by the proxy) --------------------
# The proxy authenticates to each upstream vendor with these keys. Clients
# never supply provider keys. Only set the vendors you actually route to.

# OpenAI (provider default — used for any OpenAI model without its own key)
OPENAI_API_KEY=

# Anthropic (Claude). In v1, Claude is reached via Anthropic's
# OpenAI-compatible endpoint (see ADR 0001).
ANTHROPIC_API_KEY=

# Additional vendors (all via their OpenAI-compatible endpoints). Only set the
# ones you actually route to; catalog entries without a key still appear in the
# demo/inspector but can't be forwarded to.
GOOGLE_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
COHERE_API_KEY=

# --- Per-model keys (optional, for per-model cost breakdown) ----------------
# A model in config/models.yaml may set `api_key_env: SOME_VAR`. If that var is
# set here, the proxy authenticates that model's calls with it (so the vendor
# bills it separately); otherwise it falls back to the provider key above.
# The var name is whatever you put in models.yaml — e.g.:
# OPENAI_API_KEY_GPT_4_1=

# --- Classifier credentials (optional) -------------------------------------
# The classifier model/endpoint is selected in config/server.yaml. If the
# classifier runs against a different account or gateway than the routed
# providers, put its key here; otherwise it reuses the matching provider key
# above.
CLASSIFIER_API_KEY=

# --- Proxy auth: OAuth 2.0 client credentials (ADR 0015) -------------------
# The /v1 surface is protected by validating JWT access tokens. These are NOT
# secrets — the issuer's public keys do the validating — so they live here (or
# in config/server.yaml) purely for convenience.
#
# Leave the issuer empty to fail closed (every /v1 request answers 401) while
# /demo and /v1/router/explain stay open — the demo-only posture.
#
# AUTH_ENABLED toggles the whole OAuth check. false => /v1 is fully open (no
# token required) — local dev only. true (the default) => tokens are validated.
# AUTH_ENABLED=false
#
# AUTH_ISSUER=https://login.example.com/     # iss must match; JWKS discovered here
# AUTH_AUDIENCE=api://corgi-ai-gateway       # aud must match
# AUTH_REQUIRED_SCOPE=router.invoke          # optional
# AUTH_JWKS_URI=                             # optional override of the discovered JWKS

# --- RouteLLM sidecar (optional) -------------------------------------------
# Shows the learned win-rate signal alongside the classifier in the demo
# (ADR 0006). The sidecar is opt-in at the compose level too:
#   docker compose --profile routellm up -d --build
# Leave false unless that sidecar is actually running — when it is enabled but
# unreachable the router degrades gracefully, but pays a failed call per request.
ROUTELLM_ENABLED=false

# --- Observability (optional) ----------------------------------------------
# Azure Monitor / Application Insights connection string. Required only when
# telemetry.azure_monitor.enabled is true in config/server.yaml. It is a secret.
# See docs/help/observability.md.
APPLICATIONINSIGHTS_CONNECTION_STRING=

# --- Self-hosted / Ollama (future) -----------------------------------------
# Placeholder for when local/self-hosted backends are added. Ollama typically
# needs no key; set the base URL in config/server.yaml.
# OLLAMA_API_KEY=
