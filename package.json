{
  "name": "corgi-ai-gateway",
  "version": "0.1.0",
  "description": "OpenAI-compatible LLM routing proxy that picks the best model per request",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "eval": "tsx eval/run.ts",
    "eval:judge": "tsx eval/judge-run.ts",
    "eval:baseline": "tsx eval/baseline-run.ts",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@azure/monitor-opentelemetry-exporter": "^1.0.0-beta.32",
    "@hono/node-server": "^2.0.11",
    "@hono/swagger-ui": "^0.5.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.221.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.221.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.221.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.221.0",
    "@opentelemetry/resources": "^2.10.0",
    "@opentelemetry/sdk-logs": "^0.221.0",
    "@opentelemetry/sdk-metrics": "^2.10.0",
    "@opentelemetry/sdk-trace-base": "^2.10.0",
    "@opentelemetry/sdk-trace-node": "^2.10.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "dotenv": "^16.4.0",
    "gpt-tokenizer": "^3.4.0",
    "hono": "^4.6.0",
    "jose": "^6.2.4",
    "openai": "^6.48.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.0"
  },
  "//overrides": "The Azure Monitor exporter bundles an older @opentelemetry/sdk-logs that pulls a @opentelemetry/core affected by GHSA-8988-4f7v-96qf (baggage DoS). No fixed Azure release exists yet, so force the nested copies to the patched 2.x line (same major the bundled sdk-logs targets).",
  "overrides": {
    "@opentelemetry/core": "^2.10.0",
    "@opentelemetry/resources": "^2.10.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "@vitest/coverage-v8": "^4.1.10",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10"
  }
}
